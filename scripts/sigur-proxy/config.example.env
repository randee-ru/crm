# Локальный прокси Sigur → 1С + CRM Kit (облако)
# Скопируйте в .env на сервере клуба и подставьте свои значения.

SIGUR_PROXY_HOST=127.0.0.1
SIGUR_PROXY_PORT=9000

# 1С на том же сервере — локальные адреса
ONEC_SIGUR_GETACCESS_URL=http://127.0.0.1:85/Fitness_PROF/hs/sigur/getaccess
ONEC_SIGUR_EVENTS_URL=http://127.0.0.1:85/Fitness_PROF/hs/sigur/events
ONEC_SIGUR_BASIC_USER=sigur
ONEC_SIGUR_BASIC_PASSWORD=смените-пароль

# Облачный CRM Kit — URL из настроек интеграции Sigur
CRM_SIGUR_EVENTS_URL=https://ваш-crm.example.com/api/v1/integrations/sigur/inbound/events/?company=sportmax
CRM_SIGUR_PROXY_KEY=ключ-из-config-интеграции-sigur
CRM_SIGUR_FORWARD_TIMEOUT=5
