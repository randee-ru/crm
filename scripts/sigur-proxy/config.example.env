# =============================================================================
# Файл настроек для proxy.py на СЕРВЕРЕ КЛУБА (скопируйте в .env)
# =============================================================================

# Прокси слушает только localhost — Sigur на том же сервере обращается сюда.
SIGUR_PROXY_HOST=127.0.0.1
SIGUR_PROXY_PORT=9000

# -----------------------------------------------------------------------------
# 1С — на том же сервере, быстрые локальные адреса (НЕ 195.216.241.93)
# -----------------------------------------------------------------------------
ONEC_SIGUR_GETACCESS_URL=http://127.0.0.1:85/Fitness_PROF/hs/sigur/getaccess
ONEC_SIGUR_EVENTS_URL=http://127.0.0.1:85/Fitness_PROF/hs/sigur/events
ONEC_SIGUR_BASIC_USER=sigur
ONEC_SIGUR_BASIC_PASSWORD=ваш-пароль-1с

# -----------------------------------------------------------------------------
# Облачный CRM Kit — сюда уходит КОПИЯ проходов (после успешной записи в 1С)
#
# URL взять из CRM: Настройки → Интеграции → Sigur
# Ключ CRM_SIGUR_PROXY_KEY = config.proxy_inbound_key из той же интеграции
# -----------------------------------------------------------------------------
CRM_SIGUR_EVENTS_URL=https://ваш-crm.example.com/api/v1/integrations/sigur/inbound/events/?company=sportmax
CRM_SIGUR_PROXY_KEY=вставьте-ключ-из-облачного-crm
CRM_SIGUR_FORWARD_TIMEOUT=5
