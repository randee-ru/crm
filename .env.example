# Пример переменных окружения для корня проекта.
# Скопируйте этот файл в `.env` и подстройте значения под свою машину.

DJANGO_SECRET_KEY=change-me-in-local-development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

POSTGRES_DB=crm_kit
POSTGRES_USER=crm_kit
POSTGRES_PASSWORD=crm_kit
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
