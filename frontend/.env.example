# Пример переменных окружения для frontend.
# Скопируйте этот файл в `.env.local`, если хотите изменить адрес backend.

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_COMPANY_SLUG=sportmax
# Server-side URL for Next API routes that proxy to Django (IP forwarding for SMS OTP).
BACKEND_API_BASE_URL=http://127.0.0.1:8000
# Публичный URL (ngrok) — тот же, что PUBLIC_APP_URL в backend/.env
NEXT_PUBLIC_APP_URL=https://your-subdomain.ngrok-free.dev
NEXT_PUBLIC_SCHEDULE_HOST=schedule.sportmax.fit
NEXT_PUBLIC_SCHEDULE_URL=https://schedule.sportmax.fit
NEXT_PUBLIC_CLIENT_LK_HOST=lk.sportmax.fit
NEXT_PUBLIC_CLIENT_LK_URL=https://lk.sportmax.fit
NEXT_PUBLIC_CRM_HOST=crm.sportmax.fit
