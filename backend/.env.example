# Пример переменных окружения только для backend.
# Держите настройки backend здесь, чтобы приложение запускалось без догадок.

DJANGO_SECRET_KEY=<set-a-secret-key>
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

POSTGRES_DB=crm_kit
POSTGRES_USER=crm_kit
POSTGRES_PASSWORD=<set-a-password>
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Телефония (опционально — ключи также хранятся в /dashboard/telephony → Настройки)
MANGO_OFFICE_API_URL=https://app.mango-office.ru/vpbx
MANGO_OFFICE_API_KEY=
MANGO_OFFICE_API_SALT=

# Публичный URL приложения для webhook Mango (ngrok при локальной разработке)
# В Mango Office → Внешние системы укажите: {PUBLIC_APP_URL}/api/mango/callback
# Для MAX Bot API webhook: {PUBLIC_APP_URL}/api/channels/webhooks/max?company=<slug>
PUBLIC_APP_URL=https://your-subdomain.ngrok-free.dev

# Messenger gateway (личные аккаунты MAX / WhatsApp / Telegram)
MESSENGER_GATEWAY_URL=http://127.0.0.1:8787
MESSENGER_GATEWAY_SECRET=<set-a-secret>
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Бот push-уведомлений владельцу (новые записи, сообщения клиентов, лиды, ошибки сервера).
# Токен получить у @BotFather, chat_id — написать боту и запросить
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# SMS.ru для кодов входа в публичное расписание (также можно сохранить в CRM → Настройки → Расписание)
# Без имени отправителя — стандартный SMS.ru, без ежемесячной платы за буквенное имя.
SMS_RU_API_ID=

# Расшифровка звонков Whisper + AI-отчёты
OPENAI_API_KEY=
# Модели OpenAI (по умолчанию whisper-1 и gpt-4o-mini)
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_REPORT_MODEL=gpt-4o-mini
