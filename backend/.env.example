# Пример переменных окружения только для backend.
# Держите настройки backend здесь, чтобы приложение запускалось без догадок.

DJANGO_SECRET_KEY=change-me-in-local-development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

POSTGRES_DB=crm_kit
POSTGRES_USER=crm_kit
POSTGRES_PASSWORD=crm_kit
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Телефония (опционально — ключи также хранятся в /dashboard/telephony → Настройки)
MANGO_OFFICE_API_URL=https://app.mango-office.ru/vpbx
MANGO_OFFICE_API_KEY=
MANGO_OFFICE_API_SALT=

# Расшифровка звонков Whisper + AI-отчёты
OPENAI_API_KEY=
# Модели OpenAI (по умолчанию whisper-1 и gpt-4o-mini)
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_REPORT_MODEL=gpt-4o-mini
